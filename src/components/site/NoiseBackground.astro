---
---

<div class="fixed inset-0 z-0 overflow-hidden pointer-events-none" aria-hidden="true">
  <svg
    class="w-full h-full opacity-40 [mix-blend-mode:multiply] dark:opacity-[0.16] dark:[mix-blend-mode:soft-light]"
    xmlns="http://www.w3.org/2000/svg"
  >
    <filter id="desktop-noise" x="0%" y="0%" width="100%" height="100%">
      <feTurbulence type="fractalNoise" baseFrequency="0.68" numOctaves="4" stitchTiles="stitch" result="noise" />
      <feColorMatrix type="saturate" values="0" in="noise" result="mono" />
      <feComponentTransfer in="mono">
        <feFuncA type="linear" slope="0.45" />
      </feComponentTransfer>
    </filter>
    <rect width="100%" height="100%" filter="url(#desktop-noise)" />
  </svg>
</div>
