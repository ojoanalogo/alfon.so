---
import ThemeToggle from './ThemeToggle.astro';
---

<header id="main-header" class="relative z-50 overflow-visible px-2 py-4 md:px-6">
  <div class="mx-auto" data-draggable-window data-draggable-fixed style="z-index: 20;">
    <div
      class="overflow-hidden rounded-lg border border-gray-400/50 bg-white/70 font-mono text-sm backdrop-blur-lg transition-all duration-300 hover:shadow-sm dark:border-gray-400/30 dark:bg-black/10 dark:hover:shadow-md dark:hover:shadow-black/20"
    >
      <div class="window-titlebar">
        <div class="window-controls" role="group" aria-label="Controles de ventana">
          <div class="window-control window-control--close" aria-hidden="true"></div>
          <div class="window-control window-control--min" aria-hidden="true"></div>
          <div class="window-control window-control--max" aria-hidden="true"></div>
        </div>
        <div class="window-titlebar__drag cursor-grab select-none" data-drag-handle>
          <span class="window-titlebar__title">~/alfon.so</span>
        </div>
        <ThemeToggle />
      </div>
    </div>
  </div>
</header>
