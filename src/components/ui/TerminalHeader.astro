---
interface Props {
  title?: string;
  draggable?: boolean;
  closable?: boolean;
  windowId?: string;
}

const { title, draggable = false, closable = false, windowId } = Astro.props;
---

<div class="window-titlebar">
  <div class="window-controls" role="group" aria-label="Controles de ventana">
    {
      closable && windowId ? (
        <>
          <button
            type="button"
            class="window-control window-control--close"
            data-window-close={windowId}
            aria-label="Cerrar ventana"
          />
          <button
            type="button"
            class="window-control window-control--min"
            data-window-minimize={windowId}
            aria-label="Minimizar ventana"
          />
          <button
            type="button"
            class="window-control window-control--max"
            data-window-maximize={windowId}
            aria-label="Maximizar ventana"
          />
        </>
      ) : (
        <>
          <div class="window-control window-control--close" aria-hidden="true"></div>
          <div class="window-control window-control--min" aria-hidden="true"></div>
          <div class="window-control window-control--max" aria-hidden="true"></div>
        </>
      )
    }
  </div>
  <div
    class:list={['window-titlebar__drag', draggable && 'cursor-grab select-none']}
    data-drag-handle={draggable ? true : undefined}
  >
    {title && <span class="window-titlebar__title">{title}</span>}
  </div>
</div>
