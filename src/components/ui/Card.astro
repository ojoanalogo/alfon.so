---
import type { HTMLAttributes } from 'astro/types';

type Props = HTMLAttributes<'div'> & {
  /** Title bar flush to top; body content uses .card-body padding */
  windowed?: boolean;
};

const { class: className = '', windowed = false, ...attrs } = Astro.props;
---

<div
  class:list={[
    'rounded-lg border border-gray-400/50 bg-white/70 font-mono text-sm backdrop-blur-lg transition-all duration-300 hover:shadow-sm dark:border-gray-400/30 dark:bg-black/10 dark:hover:shadow-md dark:hover:shadow-black/20',
    windowed ? 'overflow-hidden p-0' : 'p-4 sm:p-6',
    className,
  ]}
  {...attrs}
>
  <slot />
</div>
