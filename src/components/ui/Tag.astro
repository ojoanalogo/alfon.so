---
interface Props {
  tag: string;
  href?: string;
}

const { tag, href } = Astro.props;

const classes =
  'px-2.5 py-1 text-xs font-medium rounded-full bg-black/[0.06] text-secondary border border-zinc-400/30 hover:bg-black/[0.1] transition-colors dark:bg-white/[0.08] dark:border-zinc-500/30 dark:hover:bg-white/[0.12]';
---

{
  href ? (
    <a href={href} class={classes}>
      #{tag}
    </a>
  ) : (
    <span class={classes}>#{tag}</span>
  )
}
