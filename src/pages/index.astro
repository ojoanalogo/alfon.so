---
import type { ImageMetadata } from 'astro';
import { getImage } from 'astro:assets';
import DesktopApp from '@/desktop/DesktopApp';
import AboutContent from '@/desktop/apps/about/AboutContent';
import Card from '../components/ui/Card.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { DESKTOP_ICON_URLS } from '@desktop/lib/desktopIcons';
import { getPublishedPosts, prepareBlogPost } from '../lib/blog';
import { sortMDByDate } from '../utils';
import type { BlogPostSummary, WallpaperOption } from '@/desktop/types';

const MAX_POSTS = 10;
const entries = sortMDByDate(await getPublishedPosts()).slice(0, MAX_POSTS);
const posts: BlogPostSummary[] = await Promise.all(entries.map((entry) => prepareBlogPost(entry)));

const wallpaperModules = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/wallpapers/*.{jpg,jpeg,png,webp}',
  { eager: true },
);

function formatWallpaperLabel(id: string) {
  return `Imagen ${id}`;
}

const wallpapers: WallpaperOption[] = (
  await Promise.all(
    Object.entries(wallpaperModules).map(async ([path, mod]) => {
      const fileName = path.split('/').pop() ?? path;
      const id = fileName.replace(/\.[^.]+$/, '');
      const srcAsset = mod.default;
      const full = await getImage({ src: srcAsset, width: 1920, format: 'webp' });
      const thumb = await getImage({ src: srcAsset, width: 280, format: 'webp' });

      return {
        id,
        label: formatWallpaperLabel(id),
        src: full.src,
        thumbSrc: thumb.src,
      };
    }),
  )
).sort((left, right) => Number(left.id) - Number(right.id));
---

<BaseLayout desktop navbarActiveItemID="home">
  <section class="sm:hidden" aria-label="Mi info">
    <Card>
      <AboutContent client:media="(max-width: 39.999rem)" posts={posts} />
    </Card>
  </section>

  <div class="relative hidden h-[calc(100dvh-2.5rem)] w-full overflow-hidden sm:block">
    <DesktopApp
      client:media="(min-width: 40rem)"
      posts={posts}
      wallpapers={wallpapers}
      desktopIconUrls={DESKTOP_ICON_URLS}
    />
  </div>
</BaseLayout>
