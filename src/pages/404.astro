---
import Card from '../components/ui/Card.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404: Not Found">
  <main class="flex justify-center">
    <Card class="w-full max-w-2xl px-2">
      <section aria-labelledby="error-heading">
        <div class="font-mono text-sm" role="region">
          <div class="text-xs">
            <div class="space-y-3">
              <div class="mb-6 flex items-center gap-4">
                <p class="text-4xl">🤔</p>
                <div class="flex flex-col">
                  <h1 id="error-heading" class="text-2xl font-bold text-red-500 dark:text-red-400">
                    404
                  </h1>
                  <p class="text-xs text-muted">Página no encontrada</p>
                </div>
              </div>

              <div class="mb-4 rounded-lg border border-red-500/30 bg-red-500/10 p-4">
                <div class="flex items-start gap-2">
                  <span class="font-bold text-red-500 dark:text-red-400">ERROR:</span>
                  <p class="leading-relaxed text-primary">
                    El recurso solicitado no se encontró en este servidor. La página que estás
                    intentando acceder no existe o ha sido movida.
                  </p>
                </div>
              </div>

              <div class="mb-3 w-full border-b border-gray-300 dark:border-gray-600"></div>

              <div class="space-y-2">
                <div class="flex">
                  <span class="w-24 shrink-0 text-muted">Status</span>
                  <span class="font-bold text-red-500 dark:text-red-400">404 No encontrado</span>
                </div>

                <div class="flex">
                  <span class="w-24 shrink-0 text-muted">Solicitud</span>
                  <span class="break-all text-primary" id="current-path"> Cargando... </span>
                </div>

                <div class="flex">
                  <span class="w-24 shrink-0 text-muted">Servidor</span>
                  <span class="text-primary">terminus v1.0</span>
                </div>

                <div class="flex">
                  <span class="w-24 shrink-0 text-muted">Fecha y hora</span>
                  <span class="text-primary" id="error-time"> Cargando... </span>
                </div>
              </div>

              <div class="my-3 w-full border-b border-gray-300 dark:border-gray-600"></div>

              <div class="space-y-2">
                <p class="mb-2 text-xs text-muted">Acciones sugeridas:</p>
                <div class="space-y-1 pl-4">
                  <p class="text-secondary">
                    <span class="text-muted">01.</span> Revisa la URL por errores de ortografía
                  </p>
                  <p class="text-secondary">
                    <span class="text-muted">02.</span> Regresa a la
                    <a href="/" class="text-primary underline hover:text-accent focus:outline-none">
                      página principal
                    </a>
                  </p>
                  <p class="text-secondary">
                    <span class="text-muted">03.</span> Explora las
                    <a
                      href="/blog"
                      class="text-primary underline hover:text-accent focus:outline-none"
                    >
                      publicaciones del blog
                    </a>
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
    </Card>
  </main>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const pathElement = document.getElementById('current-path');
      const timeElement = document.getElementById('error-time');

      if (pathElement) {
        pathElement.textContent = window.location.pathname;
      }

      if (timeElement) {
        timeElement.textContent = new Date().toISOString();
      }
    });
  </script>
</BaseLayout>
